# ============================================================================
# TRADING MODE (Development vs Production)
# ============================================================================
# Set to "production" when you're ready to trade live
# Leave as "development" for testnet/paper trading
# When set to production, bot will ask for manual confirmation

ENV=development
PAPER_TRADING=1

# Strategy selector: Strangle Regime
STRATEGY_TYPE=

# Optional Short Strangle Sidewinder sizing
BASE_LOTS=1
PROFIT_PER_LOT_ADD=8000

